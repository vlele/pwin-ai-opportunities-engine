      "trust_tier": 1,
      "access_mode": "official_api",
      "auth": {
        "type": "api_key",
        "env_var": "SAM_API_KEY",
        "required": true
      },
      "taxonomy": [
        "naics",
        "set_aside"
      ],
      "homepage": "https://sam.gov/content/opportunities",
